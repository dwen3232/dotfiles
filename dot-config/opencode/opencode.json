{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-claude-auth"],
  "permission": {
    "bash": {
      "*": "ask",
      "tree *": "allow",
      "ls *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "npx tsc *": "allow",
      "echo *": "allow",
      "mkdir *": "allow",
      "mv *": "allow"
    },
    "task": {
      "*": "deny",
      "iterate-orchestrator": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "~/Repositories/lahzo-monorepo*/**": "allow",
      "~/Repositories/agent-core/**": "allow",
      "~/Repositories/lahzo-integrations/**": "allow",
      "~/Repositories/dotfiles/**": "allow",
      "~/Repositories/ui-core/**": "allow",
      "~/Repositories/infra/**": "allow"
    }
  }
}
