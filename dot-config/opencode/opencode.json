{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-claude-auth"],
  "permission": {
    "bash": {
      "*": "ask",
      "tree *": "allow",
      "ls *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "touch *": "allow",
      "cat *": "allow",
      "xargs *": "allow",
      "head *": "allow",
      "npx tsc *": "allow",
      "echo *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "rm *": "allow",
      "jq *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "pnpm *": "allow",
      "pnpm publish": "deny",
      "pnpm publish *": "deny",
      "uv *": "allow",
      "uv publish": "deny",
      "uv publish *": "deny",
      "poetry *": "allow",
      "poetry publish": "deny",
      "poetry publish *": "deny",
      "docker ps *": "allow",
      "docker images *": "allow",
      "docker logs *": "allow",
      "docker inspect *": "allow",
      "docker compose ps *": "allow",
      "docker compose logs *": "allow",
      "gcloud * list": "allow",
      "gcloud * list *": "allow",
      "gcloud * describe *": "allow",
      "terraform show *": "allow",
      "terraform output *": "allow"
    },
    "task": {
      "*": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "/Users/davidwen/Repositories/lahzo-monorepo*/**": "allow",
      "~/Repositories/agent-core/**": "allow",
      "~/Repositories/lahzo-integrations/**": "allow",
      "~/Repositories/dotfiles/**": "allow",
      "~/Repositories/ui-core/**": "allow",
      "~/Repositories/infra/**": "allow",
      "~/Repositories/lahzo-opencode-context/**": "allow"
    }
  }
}
