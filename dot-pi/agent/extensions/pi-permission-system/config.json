{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": false,
  "permission": {
    "*": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.ssh/*": "deny",
      "*.pem": "deny",
      "*.key": "deny"
    },
    "bash": {
      "*": "ask",
      "tree *": "allow",
      "ls *": "allow",
      "sed *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "touch *": "allow",
      "cat *": "allow",
      "xargs *": "allow",
      "base64 *": "allow",
      "head *": "allow",
      "npx tsc *": "allow",
      "echo *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "rm *": "allow",
      "jq *": "allow",
      "which *": "allow",
      "dirname *": "allow",
      "rsync *": "allow",
      "true *": "allow",
      "cp *": "allow",
      "sort *": "allow",
      "nl *": "allow",
      "git": "allow",
      "git *": "allow",
      "git reset": "ask",
      "git reset *": "ask",
      "git clean": "ask",
      "git clean *": "ask",
      "git checkout --": "ask",
      "git checkout -- *": "ask",
      "git restore": "ask",
      "git restore *": "ask",
      "git branch -D": "ask",
      "git branch -D *": "ask",
      "git branch -M": "ask",
      "git branch -M *": "ask",
      "git tag -d": "ask",
      "git tag -d *": "ask",
      "git stash drop": "ask",
      "git stash drop *": "ask",
      "git stash clear": "ask",
      "git stash clear *": "ask",
      "git push --force": "ask",
      "git push --force *": "ask",
      "git push --force-with-lease": "ask",
      "git push --force-with-lease *": "ask",
      "git push * --force": "ask",
      "git push * --force-with-lease": "ask",
      "git rebase": "ask",
      "git rebase *": "ask",
      "git update-ref": "ask",
      "git update-ref *": "ask",
      "pnpm *": "allow",
      "pnpm publish": "deny",
      "pnpm publish *": "deny",
      "uv *": "allow",
      "uv publish": "deny",
      "uv publish *": "deny",
      "poetry *": "allow",
      "poetry publish": "deny",
      "poetry publish *": "deny",
      "docker ps *": "allow",
      "docker images *": "allow",
      "docker logs *": "allow",
      "docker inspect *": "allow",
      "docker compose ps *": "allow",
      "docker compose logs *": "allow",
      "gcloud * list": "allow",
      "gcloud * list *": "allow",
      "gcloud * describe *": "allow",
      "terraform show *": "allow",
      "terraform output *": "allow",
      "gh *": "allow",
      "op *": "allow"
    },
    "task": "allow",
    "mcp": {
      "*": "ask",
      "mcp_status": "allow",
      "mcp_list": "allow",
      "mcp_search": "allow",
      "mcp_describe": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/Repositories/lahzo-monorepo*/*": "allow",
      "~/Repositories/agent-core/*": "allow",
      "~/Repositories/lahzo-integrations/*": "allow",
      "~/Repositories/dotfiles/*": "allow",
      "~/Repositories/ui-core/*": "allow",
      "~/Repositories/infra/*": "allow",
      "~/Repositories/multiverse/*": "allow",
      "~/Repositories/lahzo-opencode-context/*": "allow"
    }
  }
}
