{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": false,
  "permission": {
    "*": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.dev-vault": "allow",
      "~/.ssh/*": "deny",
      "*.pem": "deny",
      "*.key": "deny"
    },
    "bash": {
      "*": "allow",
      "sudo": "ask",
      "sudo *": "ask",
      "su": "ask",
      "su *": "ask",
      "rm": "ask",
      "rm *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "chgrp *": "ask",
      "git reset": "ask",
      "git reset *": "ask",
      "git clean": "ask",
      "git clean *": "ask",
      "git checkout --": "ask",
      "git checkout -- *": "ask",
      "git restore": "ask",
      "git restore *": "ask",
      "git branch -D": "ask",
      "git branch -D *": "ask",
      "git branch -M": "ask",
      "git branch -M *": "ask",
      "git tag -d": "ask",
      "git tag -d *": "ask",
      "git stash drop": "ask",
      "git stash drop *": "ask",
      "git stash clear": "ask",
      "git stash clear *": "ask",
      "git push --force": "ask",
      "git push --force *": "ask",
      "git push --force-with-lease": "ask",
      "git push --force-with-lease *": "ask",
      "git push * --force": "ask",
      "git push * --force-with-lease": "ask",
      "git rebase": "ask",
      "git rebase *": "ask",
      "git update-ref": "ask",
      "git update-ref *": "ask",
      "pnpm publish": "deny",
      "pnpm publish *": "deny",
      "npm publish": "deny",
      "npm publish *": "deny",
      "yarn publish": "deny",
      "yarn publish *": "deny",
      "uv publish": "deny",
      "uv publish *": "deny",
      "poetry publish": "deny",
      "poetry publish *": "deny",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "docker volume rm *": "ask",
      "docker system prune *": "ask",
      "docker compose down *": "ask",
      "terraform apply *": "ask",
      "terraform destroy *": "ask",
      "terraform state *": "ask",
      "kubectl delete *": "ask",
      "kubectl apply *": "ask",
      "kubectl patch *": "ask",
      "kubectl scale *": "ask",
      "gcloud * delete *": "ask",
      "gcloud * update *": "ask",
      "gcloud * create *": "ask",
      "gcloud * set-iam-policy *": "ask",
      "op *": "allow",
      "herdr *": "allow"
    },
    "task": "allow",
    "mcp": {
      "*": "ask",
      "mcp_status": "allow",
      "mcp_list": "allow",
      "mcp_search": "allow",
      "mcp_describe": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/Repositories/lahzo-monorepo*/*": "allow",
      "~/Repositories/agent-core/*": "allow",
      "~/Repositories/lahzo-integrations/*": "allow",
      "~/Repositories/dotfiles/*": "allow",
      "~/Repositories/ui-core/*": "allow",
      "~/Repositories/infra/*": "allow",
      "~/Repositories/multiverse/*": "allow",
      "~/Repositories/lahzo-opencode-context/*": "allow"
    }
  }
}
