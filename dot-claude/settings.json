{
  "alwaysThinkingEnabled": true,
  "autoCompactEnabled": false,
  "editorMode": "vim",
  "effortLevel": "high",
  "enabledPlugins": {
    "caveman@caveman": true,
    "claude-notifications@qol-plugins": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/davidwen/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(~/Repositories/agent-core/)",
      "Read(~/Repositories/lahzo-integrations/)",
      "Read(~/Repositories/dotfiles/)",
      "Read(~/Repositories/ui-core/)",
      "Read(~/Repositories/infra/)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(bq query:*)",
      "Bash(gh pr diff:*)",
      "WebSearch",
      "WebFetch"
    ],
    "defaultMode": "auto"
  },
  "plugins": [
    {
      "source": "~/.claude/plugins/marketplaces/qol-plugins/plugins/claude-notifications"
    }
  ],
  "preferredNotifChannel": "kitty",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}